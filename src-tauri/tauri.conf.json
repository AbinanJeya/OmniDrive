{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "OmniDrive",
  "version": "0.1.0",
  "identifier": "com.omnidrive.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "OmniDrive",
        "width": 1360,
        "height": 920,
        "resizable": true,
        "decorations": false
      }
    ],
    "security": {
      "capabilities": ["main-capability"],
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPCACHE/previews/**"]
      },
      "csp": "default-src 'self' ipc: http://ipc.localhost; img-src 'self' data: asset: http://asset.localhost; media-src 'self' asset: http://asset.localhost blob:; script-src 'self' https://challenges.cloudflare.com; frame-src 'self' asset: http://asset.localhost https://challenges.cloudflare.com; style-src 'self' 'unsafe-inline'; font-src 'self' data:;"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "app", "dmg", "appimage", "deb", "rpm"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "OmniDrive",
    "shortDescription": "Unified cloud storage cockpit",
    "longDescription": "OmniDrive connects multiple Google Drive accounts into one desktop file browser with previews, transfer tools, and local secure token storage.",
    "linux": {
      "appimage": {
        "bundleMediaFramework": true
      }
    },
    "windows": {
      "nsis": {
        "headerImage": "windows/installer-header.bmp",
        "installerIcon": "icons/icon.ico",
        "sidebarImage": "windows/installer-sidebar.bmp",
        "installMode": "currentUser",
        "languages": ["English"],
        "customLanguageFiles": {
          "English": "windows/English.nsh"
        },
        "displayLanguageSelector": false,
        "startMenuFolder": "OmniDrive"
      }
    }
  }
}
